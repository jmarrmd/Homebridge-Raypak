{
  "pluginAlias": "RaypakPoolHeater",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Raypak Pool Heater",
        "required": true
      },
      "baseUrl": {
        "title": "Base URL",
        "type": "string",
        "default": "https://connected.raypak.com",
        "description": "The base URL of the Raypak cloud API. Only change if you have a custom endpoint.",
        "required": false
      },
      "username": {
        "title": "Username / Email",
        "type": "string",
        "description": "Your Raypak connected account email address.",
        "required": true
      },
      "password": {
        "title": "Password",
        "type": "string",
        "description": "Your Raypak connected account password.",
        "required": true
      },
      "pollInterval": {
        "title": "Poll Interval (minutes)",
        "type": "number",
        "default": 1,
        "minimum": 0.5,
        "description": "How often to poll the heater for status updates, in minutes. Default: 1."
      }
    }
  },
  "layout": [
    "name",
    "username",
    {
      "key": "password",
      "type": "password"
    },
    {
      "type": "fieldset",
      "title": "Advanced Options",
      "expandable": true,
      "items": ["baseUrl", "pollInterval"]
    }
  ]
}
